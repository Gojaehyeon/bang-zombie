{
  "name": "bang-zombie",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "screenshots:readme": "node scripts/capture-readme-screenshots.mjs",
    "electron": "electron .",
    "electron:dev": "concurrently -k -s first \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "app:build": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.14",
    "@supabase/supabase-js": "^2.103.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "puppeteer": "^24.41.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "dev.bangzombie.app",
    "productName": "Bang Zombie",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        {
          "target": "dir",
          "arch": "arm64"
        }
      ],
      "extendInfo": {
        "NSCameraUsageDescription": "손을 권총으로 인식해서 좀비를 쏘기 위해 카메라가 필요합니다."
      }
    }
  }
}
